{
  "policy": {
    "policy_id": "axira-traces-14d",
    "description": "Axira traces: hot only, 14d retention, daily force-merge to 1 segment for best_compression",
    "default_state": "hot",
    "states": [
      {
        "name": "hot",
        "actions": [
          {
            "rollover": {
              "min_size": "20gb",
              "min_index_age": "1d"
            }
          }
        ],
        "transitions": [
          {
            "state_name": "force_merge",
            "conditions": { "min_index_age": "1d" }
          }
        ]
      },
      {
        "name": "force_merge",
        "actions": [
          {
            "force_merge": { "max_num_segments": 1 }
          }
        ],
        "transitions": [
          {
            "state_name": "delete",
            "conditions": { "min_index_age": "14d" }
          }
        ]
      },
      {
        "name": "delete",
        "actions": [{ "delete": {} }],
        "transitions": []
      }
    ],
    "ism_template": {
      "index_patterns": ["axira-traces-*"],
      "priority": 100
    }
  }
}
